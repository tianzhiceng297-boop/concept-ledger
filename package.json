{
  "name": "concept-forge",
  "version": "2.0.0",
  "description": "Turn vague client ideas & chaotic brainstorming into crystal-clear specs. Captures metaphors, decodes fuzzy requirements, auto-builds a shared terminology dictionary — forge raw thoughts into implementable concepts.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "build": "tsc",
    "prepack": "npm run build",
    "test": "jest --config jest.config.js"
  },
  "openclaw": {
    "extensions": ["openclaw.plugin.json"],
    "compat": {
      "pluginApi": "1.0.0"
    },
    "build": {
      "openclawVersion": "2026.3.24-beta.2"
    }
  },
  "keywords": [
    "openclaw",
    "plugin",
    "concept-forge",
    "terminology",
    "brainstorming",
    "requirements",
    "clarification",
    "specification",
    "client-communication"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "openclaw-plugin-sdk": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "openclaw-plugin-sdk": {
      "optional": true
    }
  }
}
